generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COORDINATOR
  ATTENDEE
  AUDITOR
}

enum MeetingType {
  VIRTUAL
  PHYSICAL
}

enum MeetingPlatform {
  TEAMS
  MEET
  ZOOM
  CUSTOM
  NONE
}

enum SessionType {
  SINGLE
  MULTI_DAY
}

enum MeetingStatus {
  SCHEDULED
  ACTIVE
  ENDED
  CLOSED
}

model Organisation {
  id              String    @id @default(cuid())
  name            String
  logoUrl        String?
  hrisEndpoint   String?
  hrisApiKey     String?
  brandingConfig  Json?
  retentionDays   Int       @default(365)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users           User[]
  meetings        Meeting[]
}

model User {
  id                String         @id @default(cuid())
  orgId             String
  staffId           String?
  fullName          String?
  designation       String?
  department        String?
  email             String?        @unique
  emailVerified     DateTime?
  image             String?
  role              Role           @default(ATTENDEE)
  signatureLibrary  Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  organisation      Organisation   @relation(fields: [orgId], references: [id])
  accounts          Account[]
  sessions          Session[]
  createdMeetings   Meeting[]      @relation("MeetingCreator")
  participations    Participant[]
}

model Meeting {
  id                          String          @id @default(cuid())
  orgId                       String
  creatorId                   String
  title                       String
  description                 String?
  type                        MeetingType
  platform                    MeetingPlatform @default(NONE)
  platformMeetingId           String?
  proxyLink                   String?
  originalLink                String?
  sessionType                 SessionType     @default(SINGLE)
  startDatetime               DateTime
  endDatetime                 DateTime
  venueName                   String?
  venueLat                    Float?
  venueLng                    Float?
  geoFenceRadiusM             Int             @default(100)
  attendanceThresholdMinutes  Int             @default(15)
  staffIdGateEnabled         Boolean         @default(false)
  status                      MeetingStatus   @default(SCHEDULED)
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt

  organisation                Organisation    @relation(fields: [orgId], references: [id])
  creator                     User            @relation("MeetingCreator", fields: [creatorId], references: [id])
  days                        MeetingDay[]
  participants                Participant[]
  auditLogs                   AuditLog[]
}

model MeetingDay {
  id          String   @id @default(cuid())
  meetingId   String
  dayNumber   Int
  label       String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meeting     Meeting  @relation(fields: [meetingId], references: [id])
}

model Participant {
  id                  String    @id @default(cuid())
  meetingId           String
  userId              String?
  platformJoinTime    DateTime?
  platformLeaveTime   DateTime?
  totalMinutesPresent Int       @default(0)
  thresholdMet        Boolean   @default(false)
  signInToken         String?   @unique @default(dbgenerated("gen_random_uuid()"))
  tokenExpiresAt      DateTime?
  signedAt            DateTime?
  signatureImageUrl   String?
  signatureHash       String?
  deviceFingerprint   String?
  ipAddress           String?
  gpsLat              Float?
  gpsLng              Float?
  verifiedInGeofence  Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  meeting             Meeting   @relation(fields: [meetingId], references: [id])
  user                User?     @relation(fields: [userId], references: [id])
  auditLogs           AuditLog[]
}

model AuditLog {
  id            String      @id @default(cuid())
  meetingId     String?
  participantId String?
  eventType     String
  timestamp     DateTime    @default(now())
  metadata      Json?

  meeting       Meeting?    @relation(fields: [meetingId], references: [id])
  participant   Participant? @relation(fields: [participantId], references: [id])
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
